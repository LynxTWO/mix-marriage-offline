{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/scene.schema.json",
  "title": "MMO Scene",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scene_id",
    "source",
    "objects",
    "beds",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "scene_id": { "type": "string", "minLength": 1 },
    "generated_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
    },
    "source": { "$ref": "#/$defs/source" },
    "source_refs": { "$ref": "#/$defs/source_refs" },
    "intent": { "$ref": "#/$defs/object_intent" },
    "timeline": { "$ref": "timeline.schema.json" },
    "objects": {
      "type": "array",
      "items": { "$ref": "#/$defs/object_entry" }
    },
    "beds": {
      "type": "array",
      "items": { "$ref": "#/$defs/bed_entry" }
    },
    "rules": { "$ref": "#/$defs/scene_rules" },
    "routing_intent": { "$ref": "#/$defs/routing_intent" },
    "metadata": { "$ref": "#/$defs/metadata" }
  },
  "$defs": {
    "raw_tag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "container", "scope", "key", "value", "index"],
      "properties": {
        "source": { "type": "string", "enum": ["format", "stream"] },
        "container": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "minLength": 1 },
        "value": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 }
      }
    },
    "tag_bag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw", "normalized", "warnings"],
      "properties": {
        "raw": {
          "type": "array",
          "items": { "$ref": "#/$defs/raw_tag" }
        },
        "normalized": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["technical", "tags"],
      "properties": {
        "technical": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "integer" },
              { "type": "number" },
              { "type": "string" },
              { "type": "boolean" },
              { "type": "null" }
            ]
          }
        },
        "tags": { "$ref": "#/$defs/tag_bag" }
      }
    },
    "posix_abs_path": {
      "type": "string",
      "pattern": "^(?:[A-Za-z]:/|/).+"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stems_dir", "created_from"],
      "properties": {
        "report_id": { "type": "string", "minLength": 1 },
        "stems_dir": { "$ref": "#/$defs/posix_abs_path" },
        "lock_hash": { "type": "string", "minLength": 1 },
        "created_from": {
          "type": "string",
          "enum": ["analyze", "apply", "render", "variants", "draft"]
        }
      }
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stems_map_ref", "bus_plan_ref"],
      "properties": {
        "stems_map_ref": { "type": "string", "minLength": 1 },
        "bus_plan_ref": { "type": "string", "minLength": 1 },
        "roles_ref": { "type": "string", "minLength": 1 },
        "stems_index_ref": { "type": "string", "minLength": 1 }
      }
    },
    "scene_hint_locks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["azimuth_hint", "width_hint", "depth_hint"],
      "properties": {
        "azimuth_hint": { "type": "boolean" },
        "width_hint": { "type": "boolean" },
        "depth_hint": { "type": "boolean" }
      }
    },
    "position_intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "azimuth_deg": { "type": "number" },
        "elevation_deg": { "type": "number" }
      }
    },
    "surround_send_caps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "side_max_gain": { "type": "number", "minimum": 0, "maximum": 1 },
        "rear_max_gain": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "minProperties": 1
    },
    "height_send_caps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "top_max_gain": { "type": "number", "minimum": 0, "maximum": 1 },
        "top_front_max_gain": { "type": "number", "minimum": 0, "maximum": 1 },
        "top_rear_max_gain": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "minProperties": 1
    },
    "object_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence", "locks"],
      "properties": {
        "position": { "$ref": "#/$defs/position_intent" },
        "width": { "type": "number", "minimum": 0, "maximum": 1 },
        "depth": { "type": "number", "minimum": 0, "maximum": 1 },
        "surround_send_caps": { "$ref": "#/$defs/surround_send_caps" },
        "height_send_caps": { "$ref": "#/$defs/height_send_caps" },
        "perspective": {
          "type": "string",
          "enum": ["audience", "on_stage", "in_band", "in_orchestra"]
        },
        "loudness_bias": {
          "type": "string",
          "enum": ["forward", "neutral", "back"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "locks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "object_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "stem_id",
        "label",
        "channel_count",
        "intent",
        "notes"
      ],
      "properties": {
        "object_id": { "type": "string", "minLength": 1 },
        "stem_id": { "type": "string", "minLength": 1 },
        "role_id": {
          "type": "string",
          "pattern": "^ROLE\\.[A-Z0-9_.]+$"
        },
        "bus_id": {
          "type": "string",
          "pattern": "^BUS\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)?$"
        },
        "group_bus": {
          "type": "string",
          "pattern": "^BUS\\.[A-Z0-9_]+$"
        },
        "label": { "type": "string", "minLength": 1 },
        "channel_count": { "type": "integer", "minimum": 1 },
        "azimuth_hint": { "type": "number", "minimum": -180, "maximum": 180 },
        "width_hint": { "type": "number", "minimum": 0, "maximum": 1 },
        "depth_hint": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "locks": { "$ref": "#/$defs/scene_hint_locks" },
        "source_metadata": { "$ref": "#/$defs/source_metadata" },
        "intent": { "$ref": "#/$defs/object_intent" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "bed_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence", "locks"],
      "properties": {
        "diffuse": { "type": "number", "minimum": 0, "maximum": 1 },
        "height_send_caps": { "$ref": "#/$defs/height_send_caps" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "locks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "bed_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bed_id", "label", "kind", "intent", "notes"],
      "properties": {
        "bed_id": { "type": "string", "minLength": 1 },
        "bus_id": {
          "type": "string",
          "pattern": "^BUS\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)?$"
        },
        "stem_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "content_hint": { "type": "string", "minLength": 1 },
        "width_hint": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "label": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["field", "bed"]
        },
        "intent": { "$ref": "#/$defs/bed_intent" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "vibe_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "density_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "masking_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "translation_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "locks_receipt_source": {
      "type": "string",
      "enum": ["locked", "explicit_metadata", "inferred"]
    },
    "locks_receipt_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "stem_id",
        "role_source",
        "bus_source",
        "azimuth_source",
        "width_source",
        "surround_send_caps_source",
        "depth_source",
        "height_send_caps_source",
        "azimuth_deg",
        "width",
        "depth"
      ],
      "properties": {
        "object_id": { "type": "string", "minLength": 1 },
        "stem_id": { "type": "string", "minLength": 1 },
        "role_id": { "type": "string", "pattern": "^ROLE\\.[A-Z0-9_.]+$" },
        "bus_id": { "type": "string", "pattern": "^BUS\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)?$" },
        "group_bus": { "type": "string", "pattern": "^BUS\\.[A-Z0-9_]+$" },
        "role_source": { "$ref": "#/$defs/locks_receipt_source" },
        "bus_source": { "$ref": "#/$defs/locks_receipt_source" },
        "azimuth_source": { "$ref": "#/$defs/locks_receipt_source" },
        "width_source": { "$ref": "#/$defs/locks_receipt_source" },
        "surround_send_caps_source": { "$ref": "#/$defs/locks_receipt_source" },
        "depth_source": { "$ref": "#/$defs/locks_receipt_source" },
        "height_send_caps_source": { "$ref": "#/$defs/locks_receipt_source" },
        "azimuth_deg": { "type": ["number", "null"] },
        "width": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "depth": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "surround_send_caps": { "$ref": "#/$defs/surround_send_caps" },
        "height_send_caps": { "$ref": "#/$defs/height_send_caps" }
      }
    },
    "locks_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "objects", "unmatched_stem_ids"],
      "properties": {
        "version": { "const": "0.1.0" },
        "locks_path": { "type": "string", "pattern": "^[^\\\\]+$", "minLength": 1 },
        "objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/locks_receipt_row" }
        },
        "unmatched_stem_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile_id": { "type": "string", "minLength": 1 },
        "preset_id": { "type": "string", "minLength": 1 },
        "vibe": { "$ref": "#/$defs/vibe_snapshot" },
        "metering": { "$ref": "#/$defs/scene_metering" },
        "locks_receipt": { "$ref": "#/$defs/locks_receipt" }
      }
    },
    "layout_safety_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unknown_role_strategy",
        "default_azimuth_mode",
        "prefer_bed_for_ambient"
      ],
      "properties": {
        "unknown_role_strategy": {
          "type": "string",
          "enum": ["object_low_confidence"]
        },
        "default_azimuth_mode": {
          "type": "string",
          "enum": ["none", "center"]
        },
        "prefer_bed_for_ambient": { "type": "boolean" }
      }
    },
    "lfe_policy_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow_inferred_lfe_send", "mode"],
      "properties": {
        "allow_inferred_lfe_send": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["manual_only", "derive_if_requested"]
        }
      }
    },
    "scene_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout_safety_defaults", "lfe_policy_defaults"],
      "properties": {
        "layout_safety_defaults": { "$ref": "#/$defs/layout_safety_defaults" },
        "lfe_policy_defaults": { "$ref": "#/$defs/lfe_policy_defaults" }
      }
    },
    "scene_object_meter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_id", "stem_id"],
      "properties": {
        "object_id": { "type": "string", "minLength": 1 },
        "stem_id": { "type": "string", "minLength": 1 },
        "lufs_i": { "type": ["number", "null"] },
        "true_peak_dbtp": { "type": ["number", "null"] },
        "crest_db": { "type": ["number", "null"] },
        "correlation": { "type": ["number", "null"] }
      }
    },
    "scene_session_meter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stem_count": { "type": "integer", "minimum": 0 },
        "lufs_i_min": { "type": ["number", "null"] },
        "lufs_i_max": { "type": ["number", "null"] },
        "lufs_i_range_db": { "type": ["number", "null"] },
        "true_peak_max_dbtp": { "type": ["number", "null"] }
      }
    },
    "scene_metering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["truth", "basic", "none"] },
        "objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/scene_object_meter" }
        },
        "session": { "$ref": "#/$defs/scene_session_meter" }
      }
    },
    "routing_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggested_layout_class", "confidence"],
      "properties": {
        "suggested_layout_class": {
          "type": "string",
          "enum": ["stereo", "surround", "immersive", "unknown"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
