{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/safe_render_receipt.schema.json",
  "title": "MMO Safe-Render Receipt",
  "description": "Safe-run receipt produced by mmo render --target with plugin-chain execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "context",
    "status",
    "dry_run",
    "profile_id",
    "scene_mode",
    "scene_source_path",
    "scene_locks_source_path",
    "recommendations_summary",
    "eligible_recommendations",
    "approved_by_user",
    "blocked_recommendations",
    "applied_recommendations",
    "renderer_manifests",
    "qa_issues",
    "notes"
  ],
  "$defs": {
    "recommendation_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stem_id": { "type": "string", "minLength": 1 },
        "bus_id": { "type": "string", "minLength": 1 },
        "layout_id": { "type": "string", "minLength": 1 },
        "global": { "type": "boolean", "const": true }
      },
      "oneOf": [
        { "required": ["stem_id"] },
        { "required": ["bus_id"] },
        { "required": ["layout_id"] },
        { "required": ["global"] }
      ]
    },
    "recommendation_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["param_id", "from", "to", "unit", "confidence", "evidence_ref"],
      "properties": {
        "param_id": { "type": "string", "pattern": "^PARAM\\." },
        "from": {},
        "to": {},
        "unit": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_ref": { "type": ["string", "null"] }
      }
    },
    "rollback_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "details"],
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "details": { "type": "string", "minLength": 1 }
      }
    },
    "recommendation_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommendation_id",
        "action_id",
        "impact",
        "risk",
        "requires_approval",
        "scope",
        "deltas",
        "rollback",
        "gate_summary"
      ],
      "properties": {
        "recommendation_id": { "type": "string", "minLength": 1 },
        "issue_id": { "type": "string" },
        "action_id": { "type": "string", "minLength": 1 },
        "impact": { "type": "string", "enum": ["low", "medium", "high"] },
        "risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "requires_approval": { "type": "boolean" },
        "scope": { "$ref": "#/$defs/recommendation_scope" },
        "deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/recommendation_delta" }
        },
        "rollback": {
          "type": "array",
          "items": { "$ref": "#/$defs/rollback_step" }
        },
        "gate_summary": { "type": "string" },
        "notes": { "type": "string" },
        "eligible_auto_apply": { "type": "boolean" },
        "eligible_render": { "type": "boolean" },
        "approved_by_user": { "type": "boolean" },
        "spatial_change": { "type": "boolean" },
        "required_lock_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "context": { "type": "string", "const": "safe_render" },
    "status": { "type": "string", "enum": ["dry_run_only", "completed", "blocked"] },
    "dry_run": { "type": "boolean" },
    "target": { "type": "string" },
    "profile_id": { "type": "string", "minLength": 1 },
    "scene_mode": { "type": "string", "enum": ["explicit", "auto_built"] },
    "scene_source_path": { "type": ["string", "null"] },
    "scene_locks_source_path": { "type": ["string", "null"] },
    "approved_by": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommendations_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "eligible", "auto_eligible", "approved_by_user", "blocked", "applied"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "eligible": { "type": "integer", "minimum": 0 },
        "auto_eligible": { "type": "integer", "minimum": 0 },
        "approved_by_user": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "applied": { "type": "integer", "minimum": 0 }
      }
    },
    "eligible_recommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation_entry" }
    },
    "approved_by_user": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation_entry" }
    },
    "blocked_recommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation_entry" }
    },
    "applied_recommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation_entry" }
    },
    "renderer_manifests": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "qa_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["issue_id", "severity"],
        "properties": {
          "issue_id": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["error", "warn", "info"] },
          "message": { "type": "string" },
          "output_path": { "type": "string" },
          "metric": { "type": "string" },
          "value": {},
          "threshold": {}
        }
      }
    },
    "spectral_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
