{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/safe_render_receipt.schema.json",
  "title": "MMO Safe-Render Receipt",
  "description": "Safe-run receipt produced by mmo render --target with plugin-chain execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "context",
    "status",
    "dry_run",
    "profile_id",
    "scene_mode",
    "scene_source_path",
    "scene_locks_source_path",
    "recommendations_summary",
    "eligible_recommendations",
    "approved_by_user",
    "blocked_recommendations",
    "applied_recommendations",
    "renderer_manifests",
    "qa_issues",
    "fallback_attempts",
    "fallback_final",
    "notes"
  ],
  "$defs": {
    "recommendation_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stem_id": { "type": "string", "minLength": 1 },
        "bus_id": { "type": "string", "minLength": 1 },
        "layout_id": { "type": "string", "minLength": 1 },
        "global": { "type": "boolean", "const": true }
      },
      "oneOf": [
        { "required": ["stem_id"] },
        { "required": ["bus_id"] },
        { "required": ["layout_id"] },
        { "required": ["global"] }
      ]
    },
    "recommendation_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["param_id", "from", "to", "unit", "confidence", "evidence_ref"],
      "properties": {
        "param_id": { "type": "string", "pattern": "^PARAM\\." },
        "from": {},
        "to": {},
        "unit": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_ref": { "type": ["string", "null"] }
      }
    },
    "rollback_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "details"],
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "details": { "type": "string", "minLength": 1 }
      }
    },
    "recommendation_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommendation_id",
        "action_id",
        "impact",
        "risk",
        "requires_approval",
        "scope",
        "deltas",
        "rollback",
        "gate_summary"
      ],
      "properties": {
        "recommendation_id": { "type": "string", "minLength": 1 },
        "issue_id": { "type": "string" },
        "action_id": { "type": "string", "minLength": 1 },
        "impact": { "type": "string", "enum": ["low", "medium", "high"] },
        "risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "requires_approval": { "type": "boolean" },
        "scope": { "$ref": "#/$defs/recommendation_scope" },
        "deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/recommendation_delta" }
        },
        "rollback": {
          "type": "array",
          "items": { "$ref": "#/$defs/rollback_step" }
        },
        "gate_summary": { "type": "string" },
        "notes": { "type": "string" },
        "eligible_auto_apply": { "type": "boolean" },
        "eligible_render": { "type": "boolean" },
        "approved_by_user": { "type": "boolean" },
        "spatial_change": { "type": "boolean" },
        "required_lock_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fallback_attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "changes", "qa_before", "qa_after", "result"],
      "properties": {
        "layout_id": { "type": "string", "minLength": 1 },
        "step_id": { "type": "string", "minLength": 1 },
        "changes": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "qa_before": { "type": "object", "additionalProperties": true },
        "qa_after": { "type": "object", "additionalProperties": true },
        "result": {
          "type": "string",
          "enum": ["pass", "improved", "no_improvement"]
        },
        "improvement": { "type": "number" }
      }
    },
    "fallback_final": {
      "type": "object",
      "additionalProperties": true,
      "required": ["applied_steps", "final_outcome", "safety_collapse_applied"],
      "properties": {
        "applied_steps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "final_outcome": {
          "type": "string",
          "enum": ["not_run", "not_needed", "pass", "pass_with_safety_collapse", "fail"]
        },
        "safety_collapse_applied": { "type": "boolean" },
        "passed_layout_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "failed_layout_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deliverable_id", "label", "output_ids"],
      "properties": {
        "deliverable_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "artifact_role": { "type": "string", "minLength": 1 },
        "target_layout_id": { "type": "string", "minLength": 1 },
        "target_stem_id": { "type": "string", "minLength": 1 },
        "target_bus_id": { "type": "string", "minLength": 1 },
        "channel_count": { "type": "integer", "minimum": 1 },
        "status": {
          "type": "string",
          "enum": ["success", "failed", "partial", "invalid_master"]
        },
        "is_valid_master": { "type": "boolean" },
        "planned_stem_count": { "type": ["integer", "null"], "minimum": 0 },
        "decoded_stem_count": { "type": ["integer", "null"], "minimum": 0 },
        "prepared_stem_count": { "type": ["integer", "null"], "minimum": 0 },
        "skipped_stem_count": { "type": ["integer", "null"], "minimum": 0 },
        "rendered_frame_count": { "type": ["integer", "null"], "minimum": 0 },
        "duration_seconds": { "type": ["number", "null"], "minimum": 0 },
        "failure_reason": { "type": ["string", "null"], "minLength": 1 },
        "warning_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "formats": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "output_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "deliverables_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_status",
        "deliverable_count",
        "success_count",
        "failed_count",
        "partial_count",
        "invalid_master_count",
        "valid_master_count",
        "mixed_outcomes",
        "result_bucket",
        "top_failure_reason",
        "top_failure_status"
      ],
      "properties": {
        "overall_status": {
          "type": ["string", "null"],
          "enum": ["success", "failed", "partial", "invalid_master", null]
        },
        "deliverable_count": { "type": "integer", "minimum": 0 },
        "success_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "partial_count": { "type": "integer", "minimum": 0 },
        "invalid_master_count": { "type": "integer", "minimum": 0 },
        "valid_master_count": { "type": "integer", "minimum": 0 },
        "mixed_outcomes": { "type": "boolean" },
        "result_bucket": {
          "type": ["string", "null"],
          "enum": ["valid_master", "success_no_master", "partial_success", "diagnostics_only", "full_failure", null]
        },
        "top_failure_reason": { "type": ["string", "null"] },
        "top_failure_status": {
          "type": ["string", "null"],
          "enum": ["failed", "partial", "invalid_master", null]
        }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "context": { "type": "string", "const": "safe_render" },
    "status": { "type": "string", "enum": ["dry_run_only", "completed", "blocked"] },
    "dry_run": { "type": "boolean" },
    "target": { "type": "string" },
    "profile_id": { "type": "string", "minLength": 1 },
    "scene_mode": { "type": "string", "enum": ["explicit", "auto_built"] },
    "scene_source_path": { "type": ["string", "null"] },
    "scene_locks_source_path": { "type": ["string", "null"] },
    "approved_by": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommendations_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "eligible", "auto_eligible", "approved_by_user", "blocked", "applied"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "eligible": { "type": "integer", "minimum": 0 },
        "auto_eligible": { "type": "integer", "minimum": 0 },
        "approved_by_user": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "applied": { "type": "integer", "minimum": 0 }
      }
    },
    "eligible_recommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation_entry" }
    },
    "approved_by_user": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation_entry" }
    },
    "blocked_recommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation_entry" }
    },
    "applied_recommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation_entry" }
    },
    "deliverables": {
      "type": "array",
      "items": { "$ref": "#/$defs/deliverable" }
    },
    "deliverables_summary": {
      "$ref": "#/$defs/deliverables_summary"
    },
    "renderer_manifests": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "qa_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["issue_id", "severity"],
        "properties": {
          "issue_id": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["error", "warn", "info"] },
          "message": { "type": "string" },
          "measurement_state": {
            "type": "string",
            "enum": [
              "measured",
              "not_applicable",
              "measurement_failed",
              "invalid_due_to_silence"
            ]
          },
          "output_path": { "type": "string" },
          "metric": { "type": "string" },
          "value": {},
          "threshold": {}
        }
      }
    },
    "fallback_attempts": {
      "type": "array",
      "items": { "$ref": "#/$defs/fallback_attempt" }
    },
    "fallback_final": { "$ref": "#/$defs/fallback_final" },
    "spectral_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
