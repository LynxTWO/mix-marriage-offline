{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/plugin.schema.json",
  "title": "MMO Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["plugin_id", "plugin_type", "name", "version", "entrypoint"],
  "properties": {
    "plugin_id": {
      "type": "string",
      "description": "Canonical plugin identifier.",
      "pattern": "^PLUGIN\\.(DETECTOR|RESOLVER|RENDERER)\\.[A-Z0-9_\\.]+$"
    },
    "plugin_type": {
      "type": "string",
      "enum": ["detector", "resolver", "renderer"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "description": "Semver string.",
      "pattern": "^\\d+\\.\\d+\\.\\d+([\\-\\+][0-9A-Za-z\\.-]+)?$"
    },
    "author": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "mmo_min_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+([\\-\\+][0-9A-Za-z\\.-]+)?$"
    },
    "ontology_min_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+([\\-\\+][0-9A-Za-z\\.-]+)?$"
    },
    "entrypoint": {
      "type": "string",
      "description": "Python entrypoint in the form module.path:SymbolName",
      "pattern": "^[A-Za-z0-9_\\.]+:[A-Za-z0-9_\\.]+$"
    },
    "capabilities": {
      "description": "Optional plugin capability metadata.",
      "oneOf": [
        { "$ref": "#/$defs/legacy_capability_ids" },
        { "$ref": "#/$defs/plugin_capabilities" }
      ]
    },
    "numeric_precision": {
      "type": "string",
      "enum": ["float64"],
      "default": "float64",
      "description": "Canonical numeric precision for DSP and PCM processing."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "config_schema": {
      "type": "object",
      "description": "Optional JSON Schema fragment describing plugin-specific configuration.",
      "additionalProperties": true
    },
    "ui_layout": {
      "type": "string",
      "description": "Optional relative path to a plugin UI layout JSON file inside the plugin directory.",
      "pattern": "^(?![A-Za-z]:/)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"
    }
  },
  "$defs": {
    "legacy_capability_ids": {
      "type": "array",
      "description": "Legacy ontology IDs the plugin may emit or act upon.",
      "items": {
        "type": "string",
        "pattern": "^(ISSUE\\.|ACTION\\.|FEATURE\\.).+"
      },
      "uniqueItems": true
    },
    "plugin_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_channels": {
          "type": "integer",
          "minimum": 1
        },
        "channel_mode": {
          "type": "string",
          "enum": ["per_channel", "linked_group", "true_multichannel"],
          "description": "How the plugin processes audio channels (per ontology/plugin_semantics.yaml)."
        },
        "link_groups": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["front", "surrounds", "heights", "all", "custom"]
          },
          "uniqueItems": true,
          "description": "Channel groups active when channel_mode is linked_group."
        },
        "latency": {
          "$ref": "#/$defs/plugin_latency",
          "description": "Latency contract for host delay compensation."
        },
        "deterministic_seed_policy": {
          "type": "string",
          "enum": ["none", "seed_required", "seed_optional"],
          "description": "Plugin's determinism contract for internal randomness."
        },
        "purity": {
          "$ref": "#/$defs/plugin_purity_contract",
          "description": "Runtime purity contract for typed audio buffers and deterministic execution."
        },
        "dsp_traits": {
          "$ref": "#/$defs/plugin_dsp_traits",
          "description": "Digital-first DSP traits and measurable truth-contract claims."
        },
        "bed_only": {
          "type": "boolean",
          "description": "If true, plugin operates only on bed audio; cannot be applied to objects."
        },
        "scene_scope": {
          "type": "string",
          "enum": ["bed_only", "object_capable"],
          "description": "Explicit scene-scope safety contract for host restriction/bypass decisions."
        },
        "layout_safety": {
          "type": "string",
          "enum": ["layout_agnostic", "layout_specific"],
          "description": "Explicit layout-safety contract for host restriction/bypass decisions."
        },
        "supported_standards": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["SMPTE", "FILM", "LOGIC_PRO", "VST3", "AAF"]
          },
          "uniqueItems": true,
          "description": "Channel ordering standards the plugin supports. Omit to imply both SMPTE and FILM are supported. LOGIC_PRO and VST3 are import-side standards that MMO remaps to SMPTE internally."
        },
        "preferred_standard": {
          "type": "string",
          "enum": ["SMPTE", "FILM", "LOGIC_PRO", "VST3", "AAF"],
          "description": "Preferred channel ordering standard. Defaults to 'SMPTE' when omitted. SMPTE is the internal canonical standard for MMO."
        },
        "supported_layout_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "supported_contexts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["suggest", "auto_apply", "render"]
          },
          "uniqueItems": true
        },
        "scene": {
          "$ref": "#/$defs/plugin_scene_capabilities"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "plugin_latency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["zero", "fixed", "dynamic"],
          "description": "Latency reporting mode (per ontology/plugin_semantics.yaml)."
        },
        "samples": {
          "type": "integer",
          "minimum": 0,
          "description": "Latency in samples. Required when type is fixed."
        }
      }
    },
    "plugin_purity_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audio_buffer", "randomness", "wall_clock", "thread_scheduling"],
      "properties": {
        "audio_buffer": {
          "type": "string",
          "enum": ["typed_f64_interleaved"]
        },
        "randomness": {
          "type": "string",
          "enum": ["forbidden", "process_context_seed"]
        },
        "wall_clock": {
          "type": "string",
          "enum": ["forbidden"]
        },
        "thread_scheduling": {
          "type": "string",
          "enum": ["forbidden"]
        }
      }
    },
    "plugin_measurable_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "expected_direction"],
      "properties": {
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "expected_direction": {
          "type": "string",
          "enum": ["up", "down", "within"]
        },
        "threshold": {
          "type": "number"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "plugin_dsp_traits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier",
        "linearity",
        "phase_behavior",
        "adds_noise",
        "introduces_harmonics",
        "anti_aliasing",
        "measurable_claims"
      ],
      "properties": {
        "tier": {
          "type": "string",
          "enum": [
            "information_preserving",
            "controlled_nonlinear",
            "creative_color"
          ]
        },
        "linearity": {
          "type": "string",
          "enum": ["linear", "nonlinear"]
        },
        "phase_behavior": {
          "type": "string",
          "enum": [
            "linear_phase",
            "minimum_phase",
            "mixed",
            "unknown"
          ]
        },
        "adds_noise": {
          "type": "boolean"
        },
        "introduces_harmonics": {
          "type": "boolean"
        },
        "anti_aliasing": {
          "type": "string",
          "enum": ["none", "oversampling", "bandlimited", "na"]
        },
        "oversampling_factor": {
          "type": "integer",
          "minimum": 1
        },
        "measurable_claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/plugin_measurable_claim"
          },
          "minItems": 1
        }
      }
    },
    "plugin_scene_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supports_objects": {
          "type": "boolean"
        },
        "supports_beds": {
          "type": "boolean"
        },
        "supports_locks": {
          "type": "boolean"
        },
        "requires_speaker_positions": {
          "type": "boolean"
        },
        "supported_target_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^TARGET\\..+$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
