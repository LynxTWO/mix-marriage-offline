{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/project_session.schema.json",
  "title": "MMO Project Session",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scene",
    "history",
    "receipts"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "scene": {
      "type": "object"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/receipt_entry"
      }
    }
  },
  "$defs": {
    "relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "receipt_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "payload"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "payload": {
          "type": "object"
        }
      }
    }
  }
}
