{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/render_targets.schema.json",
  "title": "MMO Render Targets Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "targets"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/render_target" }
    }
  },
  "$defs": {
    "target_id": {
      "type": "string",
      "pattern": "^TARGET\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)*$"
    },
    "layout_id": {
      "type": "string",
      "pattern": "^LAYOUT\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)*$"
    },
    "speaker_id": {
      "type": "string",
      "description": "Canonical SPK.* speaker identifier, including dual-LFE IDs (SPK.LFE, SPK.LFE2).",
      "anyOf": [
        { "pattern": "^SPK\\.LFE(?:[0-9]+)?$" },
        { "pattern": "^SPK\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)*$" }
      ]
    },
    "container": {
      "type": "string",
      "enum": ["wav", "flac", "wv", "aiff", "alac"]
    },
    "filename_template": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\\\]+$",
      "allOf": [
        { "pattern": "\\{container\\}" }
      ]
    },
    "render_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "layout_id",
        "container",
        "filename_template"
      ],
      "properties": {
        "target_id": { "$ref": "#/$defs/target_id" },
        "layout_id": { "$ref": "#/$defs/layout_id" },
        "container": { "$ref": "#/$defs/container" },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "channel_order": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "channel_order_layout_id": { "$ref": "#/$defs/layout_id" },
        "filename_template": { "$ref": "#/$defs/filename_template" },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "oneOf": [
        {
          "required": ["channel_order"],
          "not": { "required": ["channel_order_layout_id"] }
        },
        {
          "required": ["channel_order_layout_id"],
          "not": { "required": ["channel_order"] }
        }
      ]
    }
  }
}
