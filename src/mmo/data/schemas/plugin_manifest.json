{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/plugin_manifest.json",
  "title": "MMO DSP Hook Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plugin_id",
    "name",
    "version",
    "stage_scope",
    "authority",
    "evidence_contract",
    "action"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "plugin_id": {
      "type": "string",
      "pattern": "^DSP\\.PLUGIN\\.[A-Z0-9_.]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+([\\-\\+][0-9A-Za-z\\.-]+)?$"
    },
    "description": {
      "type": "string"
    },
    "stage_scope": {
      "type": "string",
      "enum": ["pre_bus_stem", "bus", "post_master"]
    },
    "authority": {
      "$ref": "#/$defs/authority"
    },
    "targets": {
      "$ref": "#/$defs/targets"
    },
    "evidence_contract": {
      "$ref": "#/$defs/evidence_contract"
    },
    "action": {
      "$ref": "#/$defs/action"
    }
  },
  "$defs": {
    "role_id": {
      "type": "string",
      "pattern": "^ROLE\\.[A-Z0-9_.]+$"
    },
    "bus_id": {
      "type": "string",
      "pattern": "^BUS\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)?$"
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "impact_level",
        "requires_evidence",
        "allow_on_bass_roles"
      ],
      "properties": {
        "impact_level": {
          "type": "string",
          "enum": ["low_risk", "medium", "high"]
        },
        "requires_evidence": {
          "type": "boolean"
        },
        "allow_on_bass_roles": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include_roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/role_id"
          },
          "uniqueItems": true
        },
        "exclude_roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/role_id"
          },
          "uniqueItems": true
        },
        "include_buses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bus_id"
          },
          "uniqueItems": true
        },
        "exclude_buses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bus_id"
          },
          "uniqueItems": true
        }
      }
    },
    "evidence_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_key",
        "min_confidence",
        "reason"
      ],
      "properties": {
        "metric_key": {
          "type": "string",
          "minLength": 1
        },
        "min_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "parameter_bounds"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "pattern": "^ACTION\\.[A-Z0-9_.]+$"
        },
        "parameter_bounds": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/parameter_bound"
          }
        }
      }
    },
    "parameter_bound": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      }
    }
  }
}
