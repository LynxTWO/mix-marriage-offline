{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/render_plan.schema.json",
  "title": "MMO Render Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "scene_path",
    "targets",
    "policies",
    "jobs"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "plan_id": { "type": "string", "pattern": "^PLAN\\.[A-Za-z0-9_.-]+\\.[0-9a-f]{8}$" },
    "scene_path": { "$ref": "#/$defs/posix_path" },
    "targets": {
      "type": "array",
      "items": { "$ref": "#/$defs/target_id" }
    },
    "policies": { "$ref": "#/$defs/policies" },
    "jobs": {
      "type": "array",
      "items": { "$ref": "#/$defs/job" }
    },
    "request": { "$ref": "#/$defs/request_echo" },
    "resolved": { "$ref": "#/$defs/resolved" },
    "resolved_layouts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resolved" }
    }
  },
  "$defs": {
    "posix_path": {
      "type": "string",
      "pattern": "^[^\\\\]+$",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "pattern": "^TARGET\\.[A-Z0-9_.]+$"
    },
    "layout_id": {
      "type": "string",
      "pattern": "^LAYOUT\\.[A-Z0-9_.]+$"
    },
    "downmix_policy_id": {
      "type": "string",
      "pattern": "^POLICY\\.DOWNMIX\\.[A-Z0-9_.]+$"
    },
    "loudness_profile_id": {
      "type": "string",
      "pattern": "^LOUD\\.[A-Z0-9_.]+$"
    },
    "lfe_derivation_profile_id": {
      "type": "string",
      "pattern": "^LFE_DERIVE\\.[A-Z0-9_.]+$"
    },
    "lfe_mode": {
      "type": "string",
      "enum": ["mono", "stereo"]
    },
    "speaker_id": {
      "type": "string",
      "pattern": "^SPK\\.[A-Z0-9_.]+$"
    },
    "bus_id": {
      "type": "string",
      "pattern": "^BUS\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)?$"
    },
    "channel_gains": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/speaker_id" },
      "additionalProperties": {
        "type": "number",
        "minimum": 0.0
      }
    },
    "stem_send": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stem_id",
        "role_id",
        "group_bus",
        "policy_class",
        "confidence",
        "width_hint",
        "depth_hint",
        "locks",
        "bus_trim_db",
        "gains",
        "nonzero_channels",
        "notes"
      ],
      "properties": {
        "stem_id": { "type": "string", "minLength": 1 },
        "role_id": {
          "type": "string",
          "pattern": "^ROLE\\.[A-Z0-9_.]+$"
        },
        "group_bus": { "$ref": "#/$defs/bus_id" },
        "policy_class": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "width_hint": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "depth_hint": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "locks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "bus_trim_db": { "type": "number" },
        "gains": { "$ref": "#/$defs/channel_gains" },
        "nonzero_channels": {
          "type": "array",
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "render_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "policy_id",
        "target_layout_id",
        "channel_order",
        "bus_gain_staging",
        "stem_sends",
        "notes"
      ],
      "properties": {
        "schema_version": { "const": "0.1.0" },
        "policy_id": {
          "type": "string",
          "pattern": "^POLICY\\.PLACEMENT\\.[A-Z0-9_.]+$"
        },
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "channel_order": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "bus_gain_staging": {
          "type": "object",
          "additionalProperties": false,
          "required": ["master_gain_db", "group_trims_db"],
          "properties": {
            "master_gain_db": { "type": "number" },
            "group_trims_db": {
              "type": "object",
              "propertyNames": { "$ref": "#/$defs/bus_id" },
              "additionalProperties": { "type": "number" }
            }
          }
        },
        "stem_sends": {
          "type": "array",
          "items": { "$ref": "#/$defs/stem_send" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "downmix_route_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_layout_id", "to_layout_id"],
      "properties": {
        "from_layout_id": { "$ref": "#/$defs/layout_id" },
        "to_layout_id": { "$ref": "#/$defs/layout_id" },
        "matrix_id": { "type": "string", "minLength": 1 }
      }
    },
    "downmix_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_layout_id", "to_layout_id", "policy_id", "kind"],
      "properties": {
        "from_layout_id": { "$ref": "#/$defs/layout_id" },
        "to_layout_id": { "$ref": "#/$defs/layout_id" },
        "policy_id": { "$ref": "#/$defs/downmix_policy_id" },
        "kind": {
          "type": "string",
          "enum": ["direct", "composed"]
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downmix_route_step" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "direct" } },
            "required": ["kind"]
          },
          "then": {
            "not": { "required": ["steps"] }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "composed" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["steps"]
          }
        }
      ]
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gates_policy_id": { "type": "string", "minLength": 1 },
        "downmix_policy_id": { "type": "string", "minLength": 1 },
        "loudness_profile_id": { "$ref": "#/$defs/loudness_profile_id" },
        "lfe_derivation_profile_id": { "$ref": "#/$defs/lfe_derivation_profile_id" }
      }
    },
    "request_echo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene_path"],
      "oneOf": [
        { "required": ["target_layout_id"], "not": { "required": ["target_layout_ids"] } },
        { "required": ["target_layout_ids"], "not": { "required": ["target_layout_id"] } }
      ],
      "properties": {
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "target_layout_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/layout_id" }
        },
        "scene_path": { "$ref": "#/$defs/posix_path" },
        "routing_plan_path": { "$ref": "#/$defs/posix_path" },
        "options": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "target_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/target_id" }
            },
            "output_formats": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["wav", "flac", "wv", "aiff", "alac"]
              }
            },
            "downmix_policy_id": { "type": "string", "minLength": 1 },
            "gates_policy_id": { "type": "string", "minLength": 1 },
            "loudness_profile_id": { "$ref": "#/$defs/loudness_profile_id" },
            "lfe_derivation_profile_id": { "$ref": "#/$defs/lfe_derivation_profile_id" },
            "lfe_mode": { "$ref": "#/$defs/lfe_mode" },
            "sample_rate_hz": { "type": "integer", "minimum": 8000 },
            "bit_depth": { "type": "integer", "enum": [16, 24, 32] },
            "dry_run": { "type": "boolean" },
            "max_theoretical_quality": { "type": "boolean" },
            "mix_inputs": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/mix_input" }
            },
            "plugin_chain": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/render_plugin_step" }
            }
          }
        }
      }
    },
    "render_plugin_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plugin_id"],
      "properties": {
        "plugin_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "params": { "$ref": "#/$defs/render_plugin_params" }
      }
    },
    "mix_input_role": {
      "type": "string",
      "pattern": "^[A-Z0-9_.]+$"
    },
    "mix_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "$ref": "#/$defs/posix_path" },
        "gain_db": { "type": "number" },
        "pan": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
        "mute": { "type": "boolean" },
        "role": { "$ref": "#/$defs/mix_input_role" }
      }
    },
    "render_plugin_params": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "gain_db": { "type": "number" }
      }
    },
    "resolved": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_layout_id", "channel_order"],
      "properties": {
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "channel_order": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "channel_count": { "type": "integer", "minimum": 1 },
        "family": { "type": "string", "minLength": 1 },
        "has_lfe": { "type": "boolean" },
        "downmix_policy_id": { "type": ["string", "null"] },
        "gates_policy_id": { "type": ["string", "null"] },
        "lfe_derivation_profile_id": { "type": ["string", "null"] },
        "lfe_mode": { "$ref": "#/$defs/lfe_mode" }
      }
    },
    "lfe_derivation_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "derivation_applied",
        "derivation_ran",
        "derivation_reason",
        "profile_id",
        "profile_lowpass_hz",
        "profile_slope_db_per_oct",
        "profile_trim_db",
        "lfe_mode",
        "target_lfe_channel_count",
        "chosen_sum_mode",
        "delta_db",
        "delta_threshold_db"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_applicable", "passthrough", "derived", "empty"]
        },
        "derivation_applied": { "type": "boolean" },
        "derivation_ran": { "type": "boolean" },
        "derivation_reason": { "type": "string", "minLength": 1 },
        "profile_id": { "type": ["string", "null"] },
        "profile_lowpass_hz": { "type": ["number", "null"] },
        "profile_slope_db_per_oct": { "type": ["integer", "null"] },
        "profile_trim_db": { "type": ["number", "null"] },
        "lfe_mode": { "$ref": "#/$defs/lfe_mode" },
        "target_lfe_channel_count": { "type": "integer", "minimum": 0 },
        "chosen_sum_mode": {
          "type": "string",
          "enum": [
            "not_applicable",
            "passthrough",
            "L+R",
            "L-R",
            "flipped R"
          ]
        },
        "delta_db": { "type": "number", "minimum": 0.0 },
        "delta_threshold_db": { "type": "number", "minimum": 0.0 }
      }
    },
    "job_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role"],
      "properties": {
        "path": { "$ref": "#/$defs/posix_path" },
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "job_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "format"],
      "properties": {
        "path": { "$ref": "#/$defs/posix_path" },
        "format": {
          "type": "string",
          "enum": ["wav", "flac", "wv", "aiff", "alac"]
        }
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "target_id",
        "target_layout_id",
        "output_formats",
        "contexts",
        "notes"
      ],
      "properties": {
        "job_id": { "type": "string", "pattern": "^JOB\\.[0-9]{3}$" },
        "target_id": { "$ref": "#/$defs/target_id" },
        "resolved_target_id": { "$ref": "#/$defs/target_id" },
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "routing_plan_path": { "$ref": "#/$defs/posix_path" },
        "downmix_routes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downmix_route" }
        },
        "output_formats": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["wav", "flac", "wv", "aiff", "alac"]
          }
        },
        "contexts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["render", "auto_apply"]
          }
        },
        "status": {
          "type": "string",
          "enum": ["planned", "completed", "skipped", "failed"]
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/job_input" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/job_output" }
        },
        "lfe_receipt": { "$ref": "#/$defs/lfe_derivation_receipt" },
        "render_intent": { "$ref": "#/$defs/render_intent" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
