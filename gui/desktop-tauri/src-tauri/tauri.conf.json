{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MMO Desktop",
  "version": "1.0.0",
  "identifier": "com.mixmarriageoffline.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MMO Desktop",
        "width": 1180,
        "height": 760
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$TEMP/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$LOCALDATA/**",
          "$PUBLIC/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/mmo"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "version": "1.0.0.0"
      }
    }
  }
}
