{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/render_report.schema.json",
  "title": "MMO Render Report",
  "description": "Report of a completed render pass: what was rendered, which policies applied, and QA gate summaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request",
    "jobs",
    "policies_applied",
    "qa_gates"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "request": { "$ref": "#/$defs/request_summary" },
    "jobs": {
      "type": "array",
      "items": { "$ref": "#/$defs/render_job" }
    },
    "loudness_profile_receipt": { "$ref": "#/$defs/loudness_profile_receipt" },
    "policies_applied": { "$ref": "#/$defs/policies_applied" },
    "qa_gates": { "$ref": "#/$defs/qa_gates" }
  },
  "$defs": {
    "posix_path": {
      "type": "string",
      "pattern": "^[^\\\\]+$",
      "minLength": 1
    },
    "layout_id": {
      "type": "string",
      "pattern": "^LAYOUT\\.[A-Z0-9_.]+$"
    },
    "speaker_id": {
      "type": "string",
      "pattern": "^SPK\\.[A-Z0-9_.]+$"
    },
    "loudness_profile_id": {
      "type": "string",
      "pattern": "^LOUD\\.[A-Z0-9_.]+$"
    },
    "lfe_derivation_profile_id": {
      "type": "string",
      "pattern": "^LFE_DERIVE\\.[A-Z0-9_.]+$"
    },
    "lfe_mode": {
      "type": "string",
      "enum": ["mono", "stereo"]
    },
    "target_unit": {
      "type": "string",
      "enum": ["LUFS", "LKFS"]
    },
    "loudness_scope": {
      "type": "string",
      "enum": ["broadcast", "streaming", "game", "film"]
    },
    "compliance_mode": {
      "type": "string",
      "enum": ["compliance", "informational"]
    },
    "loudness_profile_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loudness_profile_id",
        "target_loudness",
        "target_unit",
        "tolerance_lu",
        "max_true_peak_dbtp",
        "method_id",
        "method_implemented",
        "scope",
        "compliance_mode",
        "best_effort",
        "notes",
        "warnings"
      ],
      "properties": {
        "loudness_profile_id": { "$ref": "#/$defs/loudness_profile_id" },
        "target_loudness": {
          "type": "number",
          "minimum": -70.0,
          "maximum": 0.0
        },
        "target_unit": { "$ref": "#/$defs/target_unit" },
        "tolerance_lu": {
          "type": ["number", "null"],
          "minimum": 0.0,
          "maximum": 24.0
        },
        "max_true_peak_dbtp": {
          "type": "number",
          "minimum": -20.0,
          "maximum": 0.0
        },
        "method_id": {
          "type": "string",
          "minLength": 1
        },
        "method_implemented": { "type": "boolean" },
        "scope": { "$ref": "#/$defs/loudness_scope" },
        "compliance_mode": { "$ref": "#/$defs/compliance_mode" },
        "best_effort": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "request_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene_path"],
      "oneOf": [
        { "required": ["target_layout_id"], "not": { "required": ["target_layout_ids"] } },
        { "required": ["target_layout_ids"], "not": { "required": ["target_layout_id"] } }
      ],
      "properties": {
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "target_layout_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/layout_id" }
        },
        "scene_path": { "$ref": "#/$defs/posix_path" },
        "routing_plan_path": { "$ref": "#/$defs/posix_path" }
      }
    },
    "render_job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job_id", "status", "output_files"],
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^JOB\\.[0-9]{3}$"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "skipped", "failed"]
        },
        "layout_standard": {
          "type": "string",
          "enum": ["SMPTE", "FILM"],
          "description": "Channel ordering standard used for this job's output. SMPTE (default) matches WAV/FLAC/FFmpeg byte order; FILM matches pro mixing room / Pro Tools / cinema order."
        },
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "channel_count": {
          "type": "integer",
          "minimum": 1
        },
        "channel_order": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "ffmpeg_channel_layout": {
          "type": "string",
          "minLength": 1,
          "description": "Explicit FFmpeg channel layout string derived from canonical SPK channel order (example: FL+FR+FC+LFE+LFE2+SL+SR)."
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "lfe_receipt": { "$ref": "#/$defs/lfe_derivation_receipt" },
        "output_files": {
          "type": "array",
          "items": { "$ref": "#/$defs/output_file" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "output_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_path", "format"],
      "properties": {
        "file_path": { "$ref": "#/$defs/posix_path" },
        "format": {
          "type": "string",
          "enum": ["wav", "flac", "wv", "aiff", "alac"]
        },
        "channel_count": {
          "type": "integer",
          "minimum": 1
        },
        "sample_rate_hz": {
          "type": "integer",
          "minimum": 8000
        },
        "bit_depth": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 16
        },
        "metadata_receipt": {
          "$ref": "#/$defs/metadata_receipt"
        }
      }
    },
    "metadata_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_format", "embedded_keys", "skipped_keys", "warnings"],
      "properties": {
        "container_format": {
          "type": "string",
          "enum": ["wav", "flac", "wv", "aiff", "alac"]
        },
        "embedded_keys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "skipped_keys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sidecar_json_path": { "$ref": "#/$defs/posix_path" }
      }
    },
    "policies_applied": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "downmix_policy_id": {
          "type": ["string", "null"]
        },
        "gates_policy_id": {
          "type": ["string", "null"]
        },
        "lfe_derivation_profile_id": {
          "type": ["string", "null"]
        },
        "matrix_id": {
          "type": ["string", "null"]
        }
      }
    },
    "lfe_derivation_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "derivation_applied",
        "derivation_ran",
        "derivation_reason",
        "profile_id",
        "profile_lowpass_hz",
        "profile_slope_db_per_oct",
        "profile_trim_db",
        "lfe_mode",
        "target_lfe_channel_count",
        "chosen_sum_mode",
        "delta_db",
        "delta_threshold_db"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_applicable", "passthrough", "derived", "empty"]
        },
        "derivation_applied": { "type": "boolean" },
        "derivation_ran": { "type": "boolean" },
        "derivation_reason": { "type": "string", "minLength": 1 },
        "profile_id": { "type": ["string", "null"] },
        "profile_lowpass_hz": { "type": ["number", "null"] },
        "profile_slope_db_per_oct": { "type": ["integer", "null"] },
        "profile_trim_db": { "type": ["number", "null"] },
        "lfe_mode": { "$ref": "#/$defs/lfe_mode" },
        "target_lfe_channel_count": { "type": "integer", "minimum": 0 },
        "chosen_sum_mode": {
          "type": "string",
          "enum": [
            "not_applicable",
            "passthrough",
            "L+R",
            "L-R",
            "flipped R"
          ]
        },
        "delta_db": { "type": "number", "minimum": 0.0 },
        "delta_threshold_db": { "type": "number", "minimum": 0.0 }
      }
    },
    "qa_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "gates"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "not_run"]
        },
        "gates": {
          "type": "array",
          "items": { "$ref": "#/$defs/qa_gate_entry" }
        }
      }
    },
    "qa_gate_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "outcome"],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^GATE\\.[A-Z0-9_.]+$"
        },
        "outcome": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "not_run"]
        },
        "reason_id": {
          "type": "string",
          "pattern": "^REASON\\.[A-Z0-9_.]+$"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
