{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/render_report.schema.json",
  "title": "MMO Render Report",
  "description": "Report of a completed render pass: what was rendered, which policies applied, and QA gate summaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request",
    "jobs",
    "policies_applied",
    "qa_gates"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "request": { "$ref": "#/$defs/request_summary" },
    "jobs": {
      "type": "array",
      "items": { "$ref": "#/$defs/render_job" }
    },
    "loudness_profile_receipt": { "$ref": "#/$defs/loudness_profile_receipt" },
    "policies_applied": { "$ref": "#/$defs/policies_applied" },
    "qa_gates": { "$ref": "#/$defs/qa_gates" },
    "stage_metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/stage_metric_entry" }
    },
    "stage_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/stage_evidence_entry" }
    },
    "wall_clock": { "$ref": "#/$defs/wall_clock_report" }
  },
  "$defs": {
    "posix_path": {
      "type": "string",
      "pattern": "^[^\\\\]+$",
      "minLength": 1
    },
    "layout_id": {
      "type": "string",
      "pattern": "^LAYOUT\\.[A-Z0-9_.]+$"
    },
    "speaker_id": {
      "type": "string",
      "pattern": "^SPK\\.[A-Z0-9_.]+$"
    },
    "bus_id": {
      "type": "string",
      "pattern": "^BUS\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)?$"
    },
    "channel_gains": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/speaker_id" },
      "additionalProperties": {
        "type": "number",
        "minimum": 0.0
      }
    },
    "stem_send": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stem_id",
        "role_id",
        "group_bus",
        "policy_class",
        "confidence",
        "width_hint",
        "depth_hint",
        "locks",
        "bus_trim_db",
        "gains",
        "nonzero_channels",
        "notes"
      ],
      "properties": {
        "stem_id": { "type": "string", "minLength": 1 },
        "role_id": {
          "type": "string",
          "pattern": "^ROLE\\.[A-Z0-9_.]+$"
        },
        "group_bus": { "$ref": "#/$defs/bus_id" },
        "policy_class": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "width_hint": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "depth_hint": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "locks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "bus_trim_db": { "type": "number" },
        "gains": { "$ref": "#/$defs/channel_gains" },
        "nonzero_channels": {
          "type": "array",
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "render_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "policy_id",
        "target_layout_id",
        "channel_order",
        "bus_gain_staging",
        "stem_sends",
        "notes"
      ],
      "properties": {
        "schema_version": { "const": "0.1.0" },
        "policy_id": {
          "type": "string",
          "pattern": "^POLICY\\.PLACEMENT\\.[A-Z0-9_.]+$"
        },
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "channel_order": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "bus_gain_staging": {
          "type": "object",
          "additionalProperties": false,
          "required": ["master_gain_db", "group_trims_db"],
          "properties": {
            "master_gain_db": { "type": "number" },
            "group_trims_db": {
              "type": "object",
              "propertyNames": { "$ref": "#/$defs/bus_id" },
              "additionalProperties": { "type": "number" }
            }
          }
        },
        "stem_sends": {
          "type": "array",
          "items": { "$ref": "#/$defs/stem_send" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "loudness_profile_id": {
      "type": "string",
      "pattern": "^LOUD\\.[A-Z0-9_.]+$"
    },
    "lfe_derivation_profile_id": {
      "type": "string",
      "pattern": "^LFE_DERIVE\\.[A-Z0-9_.]+$"
    },
    "lfe_mode": {
      "type": "string",
      "enum": ["mono", "stereo"]
    },
    "target_unit": {
      "type": "string",
      "enum": ["LUFS", "LKFS"]
    },
    "loudness_scope": {
      "type": "string",
      "enum": ["broadcast", "streaming", "game", "film"]
    },
    "compliance_mode": {
      "type": "string",
      "enum": ["compliance", "informational"]
    },
    "loudness_profile_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loudness_profile_id",
        "target_loudness",
        "target_unit",
        "tolerance_lu",
        "max_true_peak_dbtp",
        "method_id",
        "method_implemented",
        "scope",
        "compliance_mode",
        "best_effort",
        "notes",
        "warnings"
      ],
      "properties": {
        "loudness_profile_id": { "$ref": "#/$defs/loudness_profile_id" },
        "target_loudness": {
          "type": "number",
          "minimum": -70.0,
          "maximum": 0.0
        },
        "target_unit": { "$ref": "#/$defs/target_unit" },
        "tolerance_lu": {
          "type": ["number", "null"],
          "minimum": 0.0,
          "maximum": 24.0
        },
        "max_true_peak_dbtp": {
          "type": "number",
          "minimum": -20.0,
          "maximum": 0.0
        },
        "method_id": {
          "type": "string",
          "minLength": 1
        },
        "method_implemented": { "type": "boolean" },
        "scope": { "$ref": "#/$defs/loudness_scope" },
        "compliance_mode": { "$ref": "#/$defs/compliance_mode" },
        "best_effort": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "request_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene_path"],
      "oneOf": [
        { "required": ["target_layout_id"], "not": { "required": ["target_layout_ids"] } },
        { "required": ["target_layout_ids"], "not": { "required": ["target_layout_id"] } }
      ],
      "properties": {
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "target_layout_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/layout_id" }
        },
        "scene_path": { "$ref": "#/$defs/posix_path" },
        "routing_plan_path": { "$ref": "#/$defs/posix_path" }
      }
    },
    "render_job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job_id", "status", "output_files"],
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^JOB\\.[0-9]{3}$"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "skipped", "failed"]
        },
        "layout_standard": {
          "type": "string",
          "enum": ["SMPTE", "FILM"],
          "description": "Channel ordering standard used for this job's output. SMPTE (default) matches WAV/FLAC/FFmpeg byte order; FILM matches pro mixing room / Pro Tools / cinema order."
        },
        "target_layout_id": { "$ref": "#/$defs/layout_id" },
        "channel_count": {
          "type": "integer",
          "minimum": 1
        },
        "channel_order": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "ffmpeg_channel_layout": {
          "type": "string",
          "minLength": 1,
          "description": "Explicit FFmpeg channel layout string derived from canonical SPK channel order (example: FL+FR+FC+LFE+LFE2+SL+SR)."
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "render_intent": { "$ref": "#/$defs/render_intent" },
        "lfe_receipt": { "$ref": "#/$defs/lfe_derivation_receipt" },
        "resampling_receipt": { "$ref": "#/$defs/resampling_receipt" },
        "output_files": {
          "type": "array",
          "items": { "$ref": "#/$defs/output_file" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "output_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_path", "format"],
      "properties": {
        "file_path": { "$ref": "#/$defs/posix_path" },
        "format": {
          "type": "string",
          "enum": ["wav", "flac", "wv", "aiff", "alac"]
        },
        "channel_count": {
          "type": "integer",
          "minimum": 1
        },
        "sample_rate_hz": {
          "type": "integer",
          "minimum": 8000
        },
        "bit_depth": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 16
        },
        "metadata_receipt": {
          "$ref": "#/$defs/metadata_receipt"
        }
      }
    },
    "metadata_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_format", "embedded_keys", "skipped_keys", "warnings"],
      "properties": {
        "container_format": {
          "type": "string",
          "enum": ["wav", "flac", "wv", "aiff", "alac"]
        },
        "embedded_keys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "skipped_keys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sidecar_json_path": { "$ref": "#/$defs/posix_path" }
      }
    },
    "policies_applied": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "downmix_policy_id": {
          "type": ["string", "null"]
        },
        "gates_policy_id": {
          "type": ["string", "null"]
        },
        "lfe_derivation_profile_id": {
          "type": ["string", "null"]
        },
        "matrix_id": {
          "type": ["string", "null"]
        }
      }
    },
    "lfe_derivation_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "derivation_applied",
        "derivation_ran",
        "derivation_reason",
        "profile_id",
        "profile_lowpass_hz",
        "profile_slope_db_per_oct",
        "profile_trim_db",
        "lfe_mode",
        "target_lfe_channel_count",
        "chosen_sum_mode",
        "delta_db",
        "delta_threshold_db"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_applicable", "passthrough", "derived", "empty"]
        },
        "derivation_applied": { "type": "boolean" },
        "derivation_ran": { "type": "boolean" },
        "derivation_reason": { "type": "string", "minLength": 1 },
        "profile_id": { "type": ["string", "null"] },
        "profile_lowpass_hz": { "type": ["number", "null"] },
        "profile_slope_db_per_oct": { "type": ["integer", "null"] },
        "profile_trim_db": { "type": ["number", "null"] },
        "lfe_mode": { "$ref": "#/$defs/lfe_mode" },
        "target_lfe_channel_count": { "type": "integer", "minimum": 0 },
        "chosen_sum_mode": {
          "type": "string",
          "enum": [
            "not_applicable",
            "passthrough",
            "L+R",
            "L-R",
            "flipped R"
          ]
        },
        "delta_db": { "type": "number", "minimum": 0.0 },
        "delta_threshold_db": { "type": "number", "minimum": 0.0 }
      }
    },
    "resampling_warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warning"],
      "properties": {
        "stem_id": { "type": "string", "minLength": 1 },
        "warning": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 }
      }
    },
    "sample_rate_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_rate_hz", "stem_count"],
      "properties": {
        "sample_rate_hz": { "type": "integer", "minimum": 1 },
        "stem_count": { "type": "integer", "minimum": 0 }
      }
    },
    "family_sample_rate_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family_sample_rate_hz", "stem_count", "max_sample_rate_hz"],
      "properties": {
        "family_sample_rate_hz": { "type": "integer", "minimum": 1 },
        "stem_count": { "type": "integer", "minimum": 0 },
        "max_sample_rate_hz": { "type": "integer", "minimum": 1 }
      }
    },
    "stem_sample_rate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stem_id", "sample_rate_hz"],
      "properties": {
        "stem_id": { "type": "string", "minLength": 1 },
        "sample_rate_hz": { "type": ["integer", "null"], "minimum": 1 },
        "sample_rate_source": { "type": "string", "minLength": 1 }
      }
    },
    "resampled_stem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stem_id", "from_sample_rate_hz", "to_sample_rate_hz"],
      "properties": {
        "stem_id": { "type": "string", "minLength": 1 },
        "from_sample_rate_hz": { "type": "integer", "minimum": 1 },
        "to_sample_rate_hz": { "type": "integer", "minimum": 1 },
        "format": { "type": "string", "minLength": 1 }
      }
    },
    "native_rate_stem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stem_id", "sample_rate_hz"],
      "properties": {
        "stem_id": { "type": "string", "minLength": 1 },
        "sample_rate_hz": { "type": "integer", "minimum": 1 },
        "format": { "type": "string", "minLength": 1 }
      }
    },
    "resampling_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_policy",
        "selection_reason",
        "selected_sample_rate_hz",
        "selected_family_sample_rate_hz",
        "selected_family_reason",
        "sample_rate_counts",
        "family_sample_rate_counts",
        "selected_family_sample_rate_counts",
        "default_sample_rate_hz",
        "stem_count_considered",
        "stem_sample_rates",
        "decoder_warnings"
      ],
      "properties": {
        "selection_policy": { "type": "string", "minLength": 1 },
        "selection_reason": { "type": "string", "minLength": 1 },
        "selected_sample_rate_hz": { "type": "integer", "minimum": 1 },
        "selected_family_sample_rate_hz": { "type": "integer", "minimum": 1 },
        "selected_family_reason": { "type": "string", "minLength": 1 },
        "sample_rate_counts": {
          "type": "array",
          "items": { "$ref": "#/$defs/sample_rate_count" }
        },
        "family_sample_rate_counts": {
          "type": "array",
          "items": { "$ref": "#/$defs/family_sample_rate_count" }
        },
        "selected_family_sample_rate_counts": {
          "type": "array",
          "items": { "$ref": "#/$defs/sample_rate_count" }
        },
        "default_sample_rate_hz": { "type": "integer", "minimum": 1 },
        "stem_count_considered": { "type": "integer", "minimum": 0 },
        "stem_sample_rates": {
          "type": "array",
          "items": { "$ref": "#/$defs/stem_sample_rate" }
        },
        "decoder_warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/resampling_warning" }
        }
      }
    },
    "resampling_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_stem_count",
        "planned_stem_count",
        "decoded_stem_count",
        "resampled_stem_count",
        "native_rate_stem_count",
        "skipped_stem_count",
        "decoder_warning_count"
      ],
      "properties": {
        "input_stem_count": { "type": "integer", "minimum": 0 },
        "planned_stem_count": { "type": "integer", "minimum": 0 },
        "decoded_stem_count": { "type": "integer", "minimum": 0 },
        "resampled_stem_count": { "type": "integer", "minimum": 0 },
        "native_rate_stem_count": { "type": "integer", "minimum": 0 },
        "skipped_stem_count": { "type": "integer", "minimum": 0 },
        "decoder_warning_count": { "type": "integer", "minimum": 0 }
      }
    },
    "resampling_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "selection",
        "target_sample_rate_hz",
        "counts",
        "resampled_stems",
        "native_rate_stems",
        "decoder_warnings"
      ],
      "properties": {
        "algorithm": { "type": "string", "minLength": 1 },
        "selection": { "$ref": "#/$defs/resampling_selection" },
        "target_sample_rate_hz": { "type": "integer", "minimum": 1 },
        "counts": { "$ref": "#/$defs/resampling_counts" },
        "resampled_stems": {
          "type": "array",
          "items": { "$ref": "#/$defs/resampled_stem" }
        },
        "native_rate_stems": {
          "type": "array",
          "items": { "$ref": "#/$defs/native_rate_stem" }
        },
        "decoder_warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/resampling_warning" }
        }
      }
    },
    "export_finalization_seed_derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "job_id", "layout_id", "render_seed"],
      "properties": {
        "algorithm": { "type": "string", "minLength": 1 },
        "job_id": { "type": "string", "minLength": 1 },
        "layout_id": { "type": "string", "minLength": 1 },
        "stem_id": { "type": "string", "minLength": 1 },
        "render_seed": { "type": "integer", "minimum": 0 }
      }
    },
    "export_finalization_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bit_depth",
        "dither_policy",
        "seed_derivation",
        "clamp_behavior",
        "target_peak_dbfs"
      ],
      "properties": {
        "bit_depth": { "type": "integer", "enum": [16, 24, 32] },
        "dither_policy": { "type": "string", "enum": ["none", "tpdf", "tpdf_hp"] },
        "seed_derivation": { "$ref": "#/$defs/export_finalization_seed_derivation" },
        "clamp_behavior": { "type": "string", "minLength": 1 },
        "target_peak_dbfs": { "type": ["number", "null"] }
      }
    },
    "qa_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "gates"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "not_run"]
        },
        "gates": {
          "type": "array",
          "items": { "$ref": "#/$defs/qa_gate_entry" }
        }
      }
    },
    "qa_gate_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "outcome"],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^GATE\\.[A-Z0-9_.]+$"
        },
        "outcome": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "not_run"]
        },
        "reason_id": {
          "type": "string",
          "pattern": "^REASON\\.[A-Z0-9_.]+$"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "stage_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "stage_scope": {
      "type": "string",
      "minLength": 1
    },
    "stage_where": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stage_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 }
      }
    },
    "stage_metric_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "scope", "where", "metrics", "notes"],
      "properties": {
        "stage_id": { "$ref": "#/$defs/stage_id" },
        "scope": { "$ref": "#/$defs/stage_scope" },
        "where": { "$ref": "#/$defs/stage_where" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/stage_metric" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "export_finalization_receipt": {
          "$ref": "#/$defs/export_finalization_receipt"
        }
      }
    },
    "stage_evidence_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["codes", "metrics", "notes"],
      "properties": {
        "codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/stage_metric" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stage_evidence_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "scope", "where", "evidence"],
      "properties": {
        "stage_id": { "$ref": "#/$defs/stage_id" },
        "scope": { "$ref": "#/$defs/stage_scope" },
        "where": { "$ref": "#/$defs/stage_where" },
        "evidence": { "$ref": "#/$defs/stage_evidence_payload" }
      }
    },
    "wall_clock_stage_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "scope", "where", "elapsed_seconds"],
      "properties": {
        "stage_id": { "$ref": "#/$defs/stage_id" },
        "scope": { "$ref": "#/$defs/stage_scope" },
        "where": { "$ref": "#/$defs/stage_where" },
        "elapsed_seconds": {
          "type": "number",
          "minimum": 0.0
        }
      }
    },
    "wall_clock_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "disclaimer", "stages"],
      "properties": {
        "enabled": { "const": true },
        "disclaimer": { "type": "string", "minLength": 1 },
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/wall_clock_stage_entry" }
        }
      }
    }
  }
}
