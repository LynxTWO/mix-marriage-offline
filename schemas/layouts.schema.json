{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/layouts.schema.json",
  "title": "MMO Layouts Registry",
  "description": "Validates ontology/layouts.yaml: canonical channel layouts with speaker positions and LFE policy.",
  "type": "object",
  "additionalProperties": false,
  "required": ["layouts"],
  "properties": {
    "layouts": {
      "type": "object",
      "description": "Map of LAYOUT.* IDs to layout entries. _meta key is reserved.",
      "properties": {
        "_meta": { "$ref": "#/$defs/layout_meta" }
      },
      "patternProperties": {
        "^LAYOUT\\.": { "$ref": "#/$defs/layout_entry" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "speaker_id": {
      "type": "string",
      "pattern": "^SPK\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)*$"
    },
    "lfe_speaker_id": {
      "type": "string",
      "pattern": "^SPK\\.LFE(?:[0-9]+)?$"
    },
    "layout_meta": {
      "type": "object",
      "description": "Optional _meta block at the top of the layouts map.",
      "properties": {
        "layouts_version": { "type": "string" },
        "id_prefix": { "type": "string" },
        "channel_index_base": { "type": "integer" },
        "ordering_standards": { "type": "array", "items": { "type": "string" } },
        "conventions": { "type": "array", "items": { "type": "string" } },
        "channel_groups": { "type": "object" }
      },
      "additionalProperties": true
    },
    "layout_entry": {
      "type": "object",
      "description": "A single layout definition.",
      "additionalProperties": true,
      "required": ["label", "channel_count", "channel_order", "has_lfe"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "family": { "type": "string", "enum": ["mono", "stereo", "surround", "immersive"] },
        "channel_count": { "type": "integer", "minimum": 1, "maximum": 128 },
        "ordering_standard": { "type": "string" },
        "channel_order": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/speaker_id" }
        },
        "ordering_variants": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/speaker_id" }
          }
        },
        "channel_groups": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/speaker_id" }
          }
        },
        "bed_speakers": { "type": "array", "items": { "$ref": "#/$defs/speaker_id" } },
        "height_speakers": { "type": "array", "items": { "$ref": "#/$defs/speaker_id" } },
        "has_lfe": { "type": "boolean" },
        "speaker_positions": {
          "type": "array",
          "items": { "$ref": "#/$defs/speaker_position_entry" }
        },
        "lfe_policy": { "$ref": "#/$defs/lfe_policy" },
        "recommended_downmix_targets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "speaker_position_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spk_id", "azimuth_deg", "elevation_deg"],
      "properties": {
        "spk_id": { "type": "string", "pattern": "^SPK\\." },
        "azimuth_deg": { "type": "number", "minimum": -180, "maximum": 180 },
        "elevation_deg": { "type": "number", "minimum": -90, "maximum": 90 }
      }
    },
    "lfe_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["has_lfe", "lfe_channels", "excluded_from_program_loudness", "default_downmix_treatment"],
      "properties": {
        "has_lfe": { "type": "boolean" },
        "lfe_channels": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/lfe_speaker_id" }
        },
        "excluded_from_program_loudness": { "const": true },
        "default_downmix_treatment": {
          "type": "string",
          "enum": ["drop", "fold_at_minus_10db", "passthrough", "n/a"]
        },
        "fold_at_minus_10db_available": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "has_lfe": { "const": true } },
            "required": ["has_lfe"]
          },
          "then": {
            "properties": {
              "lfe_channels": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": { "has_lfe": { "const": false } },
            "required": ["has_lfe"]
          },
          "then": {
            "properties": {
              "lfe_channels": { "maxItems": 0 }
            }
          }
        }
      ]
    }
  }
}
