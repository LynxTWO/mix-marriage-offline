{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/event.schema.json",
  "title": "MMO Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "kind", "scope", "what", "why", "where", "evidence"],
  "properties": {
    "event_id": {
      "type": "string",
      "anyOf": [
        {
          "pattern": "^EVT\\.[a-f0-9]{12,64}$"
        },
        {
          "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89ABab][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
        }
      ]
    },
    "ts_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "kind": {
      "type": "string",
      "enum": ["info", "warn", "error", "action"]
    },
    "scope": {
      "type": "string",
      "enum": ["stems", "render", "qa", "ui"]
    },
    "what": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "why": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "where": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[^\\\\]+$"
      }
    },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "number"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\\\]+$"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        }
      }
    }
  }
}
