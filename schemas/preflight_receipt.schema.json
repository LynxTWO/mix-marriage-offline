{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/preflight_receipt.schema.json",
  "title": "MMO Preflight Receipt",
  "description": "Receipt produced by evaluate_preflight() before any render (DoD 4.4.3 + 4.6). Operates on session/scene metadata only — no audio decoding required.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gates_evaluated",
    "issues",
    "downmix_checks",
    "scene_stem_overlap_summary",
    "phase_report",
    "confidence_summary",
    "final_decision"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "target_layout_id": {
      "type": "string",
      "minLength": 1
    },
    "source_layout_id": {
      "type": ["string", "null"]
    },
    "gates_evaluated": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate_result" }
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/preflight_issue" }
    },
    "downmix_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/downmix_check" }
    },
    "scene_stem_overlap_summary": {
      "$ref": "#/$defs/scene_stem_overlap_summary"
    },
    "phase_report": {
      "$ref": "#/$defs/phase_report"
    },
    "confidence_summary": {
      "$ref": "#/$defs/confidence_summary"
    },
    "final_decision": {
      "type": "string",
      "enum": ["pass", "warn", "block"]
    },
    "user_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "measured_similarity_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/measured_downmix_check" }
    }
  },
  "$defs": {
    "gate_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "outcome", "severity"],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^GATE\\.[A-Z0-9_.]+$"
        },
        "outcome": {
          "type": "string",
          "enum": ["pass", "warn", "block", "skipped"]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warn", "error"]
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "preflight_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "severity", "message"],
      "properties": {
        "issue_id": {
          "type": "string",
          "pattern": "^ISSUE\\.[A-Z0-9_.]+$"
        },
        "severity": {
          "type": "string",
          "enum": ["warn", "error"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "remedy": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "scene_overlap_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_type", "target_id", "field", "stem_ref"],
      "properties": {
        "target_type": { "type": "string", "minLength": 1 },
        "target_id": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 },
        "stem_ref": { "type": "string", "minLength": 1 }
      }
    },
    "scene_stem_overlap_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "scene_mode",
        "reference_count",
        "matched_count",
        "unique_matched_stem_count",
        "unresolved_count",
        "duplicate_bound_ref_count",
        "overlap_ratio",
        "minimum_ratio",
        "duplicated_stem_ids",
        "unresolved_refs",
        "issue_ids",
        "failure_reason"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_applicable", "clean", "partial", "failed"]
        },
        "scene_mode": {
          "type": ["string", "null"]
        },
        "reference_count": {
          "type": "integer",
          "minimum": 0
        },
        "matched_count": {
          "type": "integer",
          "minimum": 0
        },
        "unique_matched_stem_count": {
          "type": "integer",
          "minimum": 0
        },
        "unresolved_count": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_bound_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "overlap_ratio": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "minimum_ratio": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "duplicated_stem_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "unresolved_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/scene_overlap_ref" }
        },
        "issue_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ISSUE\\.[A-Z0-9_.]+$"
          }
        },
        "failure_reason": {
          "type": ["string", "null"]
        }
      }
    },
    "downmix_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matrix_id", "source_layout_id", "target_layout_id", "risk_level"],
      "properties": {
        "matrix_id": {
          "type": "string",
          "minLength": 1
        },
        "source_layout_id": {
          "type": "string",
          "minLength": 1
        },
        "target_layout_id": {
          "type": "string",
          "minLength": 1
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "lfe_folded": {
          "type": "boolean"
        },
        "lfe_boost_db": {
          "type": "number"
        },
        "predicted_lufs_delta": {
          "type": "number"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "phase_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correlation_risk", "polarity_risk"],
      "properties": {
        "correlation_risk": {
          "type": "string",
          "enum": ["none", "low", "medium", "high"]
        },
        "polarity_risk": {
          "type": "string",
          "enum": ["none", "low", "medium", "high"]
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "confidence_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall_confidence", "confidence_level"],
      "properties": {
        "overall_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "confidence_level": {
          "type": "string",
          "enum": ["high", "medium", "low", "very_low"]
        },
        "stem_count": {
          "type": "integer",
          "minimum": 0
        },
        "low_confidence_stems": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "measured_downmix_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "target_layout_id", "risk_level", "measured"],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^GATE\\.[A-Z0-9_.]+$"
        },
        "target_layout_id": {
          "type": "string",
          "minLength": 1
        },
        "channels": {
          "type": "integer",
          "minimum": 1
        },
        "lufs_integrated": {
          "type": ["number", "null"]
        },
        "true_peak_dbtp": {
          "type": ["number", "null"]
        },
        "true_peak_delta_db": {
          "type": ["number", "null"]
        },
        "stereo_correlation": {
          "type": ["number", "null"]
        },
        "lufs_delta_db": {
          "type": ["number", "null"]
        },
        "loudness_state": {
          "$ref": "#/$defs/measurement_state"
        },
        "peak_state": {
          "$ref": "#/$defs/measurement_state"
        },
        "correlation_state": {
          "$ref": "#/$defs/measurement_state"
        },
        "similarity_state": {
          "$ref": "#/$defs/measurement_state"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "measured": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "measurement_state": {
      "type": "string",
      "enum": [
        "measured",
        "not_applicable",
        "measurement_failed",
        "invalid_due_to_silence"
      ]
    }
  }
}
