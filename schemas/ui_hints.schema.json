{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/ui_hints.schema.json",
  "title": "MMO UI Hints Extension",
  "description": "Allowed shape for x_mmo_ui blocks embedded in plugin config JSON Schemas.",
  "type": "object",
  "additionalProperties": false,
  "required": ["widget"],
  "properties": {
    "widget": {
      "type": "string",
      "enum": ["knob", "fader", "toggle", "selector", "xy", "meter", "graph"]
    },
    "units": {
      "type": "string",
      "minLength": 1
    },
    "step": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "fine_step": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "text_entry": {
      "type": "boolean"
    },
    "modifier_key": {
      "type": "string",
      "enum": ["shift", "alt", "ctrl", "meta"]
    },
    "min": {
      "type": "number"
    },
    "max": {
      "type": "number"
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/option"
      }
    },
    "group": {
      "type": "string",
      "minLength": 1
    },
    "order": {
      "type": "integer",
      "minimum": 0
    },
    "help": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "widget": {
            "const": "selector"
          }
        }
      },
      "then": {
        "required": ["options"]
      }
    },
    {
      "if": {
        "required": ["fine_step"]
      },
      "then": {
        "required": ["step"]
      }
    }
  ],
  "$defs": {
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "label"],
      "properties": {
        "value": {
          "type": ["string", "number", "boolean"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
