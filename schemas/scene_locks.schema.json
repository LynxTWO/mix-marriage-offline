{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/scene_locks.schema.json",
  "title": "MMO Scene Locks",
  "oneOf": [
    { "$ref": "#/$defs/scene_locks_registry" },
    { "$ref": "#/$defs/scene_build_overrides" }
  ],
  "$defs": {
    "scene_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "description", "applies_to", "severity"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "applies_to": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["object", "bed", "scene"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "severity": {
          "type": "string",
          "enum": ["hard", "taste"]
        },
        "help_id": {
          "type": "string",
          "minLength": 1
        },
        "hint_short": {
          "type": "string",
          "minLength": 1
        },
        "hint_long": {
          "type": "string"
        },
        "affected_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scene_locks_registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "locks"],
      "properties": {
        "schema_version": { "const": "0.1.0" },
        "locks": {
          "type": "object",
          "patternProperties": {
            "^LOCK\\.[A-Z0-9_.]+$": { "$ref": "#/$defs/scene_lock" }
          },
          "additionalProperties": false
        }
      }
    },
    "stem_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$",
      "minLength": 1
    },
    "role_id": {
      "type": "string",
      "pattern": "^ROLE\\.[A-Z0-9_.]+$"
    },
    "bus_id": {
      "type": "string",
      "pattern": "^BUS\\.[A-Z0-9_]+(?:\\.[A-Z0-9_]+)?$"
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "azimuth_deg": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "width": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "minProperties": 1
    },
    "surround_send_caps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "side_max_gain": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rear_max_gain": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "minProperties": 1
    },
    "stem_override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role_id": { "$ref": "#/$defs/role_id" },
        "bus_id": { "$ref": "#/$defs/bus_id" },
        "placement": { "$ref": "#/$defs/placement" },
        "surround_send_caps": { "$ref": "#/$defs/surround_send_caps" },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        { "required": ["role_id"] },
        { "required": ["bus_id"] },
        { "required": ["placement"] },
        { "required": ["surround_send_caps"] }
      ]
    },
    "scene_build_overrides": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "overrides"],
      "properties": {
        "version": { "const": "0.1.0" },
        "overrides": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/stem_id" },
          "additionalProperties": { "$ref": "#/$defs/stem_override" }
        }
      }
    }
  }
}
