{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/render_manifest.schema.json",
  "title": "MMO Render Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "renderer_manifests"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "report_id": { "type": "string", "minLength": 1 },
    "renderer_manifests": {
      "type": "array",
      "items": { "$ref": "#/$defs/renderer_manifest" }
    },
    "deliverables": {
      "type": "array",
      "items": { "$ref": "#/$defs/deliverable" }
    },
    "deliverables_summary": {
      "$ref": "#/$defs/deliverables_summary"
    }
  },
  "$defs": {
    "raw_tag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "container", "scope", "key", "value", "index"],
      "properties": {
        "source": { "type": "string", "enum": ["format", "stream"] },
        "container": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "minLength": 1 },
        "value": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 }
      }
    },
    "tag_bag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw", "normalized", "warnings"],
      "properties": {
        "raw": {
          "type": "array",
          "items": { "$ref": "#/$defs/raw_tag" }
        },
        "normalized": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "export_finalization_seed_derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "job_id", "layout_id", "render_seed"],
      "properties": {
        "algorithm": { "type": "string", "minLength": 1 },
        "job_id": { "type": "string", "minLength": 1 },
        "layout_id": { "type": "string", "minLength": 1 },
        "stem_id": { "type": "string", "minLength": 1 },
        "render_seed": { "type": "integer", "minimum": 0 }
      }
    },
    "export_finalization_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bit_depth",
        "dither_policy",
        "seed_derivation",
        "clamp_behavior",
        "target_peak_dbfs"
      ],
      "properties": {
        "bit_depth": { "type": "integer", "enum": [16, 24, 32] },
        "dither_policy": { "type": "string", "enum": ["none", "tpdf", "tpdf_hp"] },
        "seed_derivation": { "$ref": "#/$defs/export_finalization_seed_derivation" },
        "clamp_behavior": { "type": "string", "minLength": 1 },
        "target_peak_dbfs": { "type": ["number", "null"] }
      }
    },
    "stem_resolution_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stem_id",
        "file_path",
        "workspace_relative_path",
        "source_ref",
        "resolution_mode",
        "resolved_path",
        "resolve_error_code",
        "resolve_error_detail"
      ],
      "properties": {
        "stem_id": { "type": ["string", "null"], "minLength": 1 },
        "file_path": { "type": ["string", "null"], "minLength": 1 },
        "workspace_relative_path": { "type": ["string", "null"], "minLength": 1 },
        "source_ref": { "type": ["string", "null"], "minLength": 1 },
        "resolution_mode": {
          "type": ["string", "null"],
          "enum": [
            "file_path_absolute",
            "stems_dir_relative",
            "workspace_relative_source_ref",
            "unresolved",
            null
          ]
        },
        "resolved_path": { "type": ["string", "null"], "minLength": 1 },
        "resolve_error_code": { "type": ["string", "null"], "minLength": 1 },
        "resolve_error_detail": { "type": ["string", "null"] }
      }
    },
    "renderer_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["renderer_id", "outputs", "skipped"],
      "properties": {
        "renderer_id": { "type": "string", "pattern": "^PLUGIN\\." },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/render_output" }
        },
        "notes": { "type": "string" },
        "received_recommendation_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "stem_resolution": {
          "type": "array",
          "items": { "$ref": "#/$defs/stem_resolution_entry" }
        },
        "skipped": {
          "type": "array",
          "items": { "$ref": "#/$defs/render_skipped" }
        }
      }
    },
    "render_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_id", "file_path"],
      "properties": {
        "output_id": { "type": "string", "minLength": 1 },
        "file_path": { "type": "string", "minLength": 1 },
        "action_id": { "type": "string", "pattern": "^ACTION\\." },
        "recommendation_id": { "type": "string", "minLength": 1 },
        "target_stem_id": { "type": "string", "minLength": 1 },
        "target_bus_id": { "type": "string", "minLength": 1 },
        "layout_id": { "type": "string", "pattern": "^LAYOUT\\." },
        "format": { "type": "string", "enum": ["wav", "flac", "wv", "aiff", "alac"] },
        "codec": { "type": "string", "minLength": 1 },
        "sample_rate_hz": { "type": "integer", "minimum": 1 },
        "bit_depth": { "type": "integer", "minimum": 1 },
        "channel_count": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "minLength": 16 },
        "notes": { "type": "string" },
        "export_finalization_receipt": { "$ref": "#/$defs/export_finalization_receipt" },
        "metadata": {
          "oneOf": [
            { "$ref": "#/$defs/tag_bag" },
            { "type": "object", "additionalProperties": true }
          ]
        }
      }
    },
    "render_skipped": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommendation_id", "action_id", "reason", "gate_summary"],
      "properties": {
        "recommendation_id": { "type": "string", "minLength": 1 },
        "action_id": { "type": "string", "pattern": "^ACTION\\." },
        "reason": { "type": "string", "minLength": 1 },
        "gate_summary": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deliverable_id", "label", "output_ids"],
      "properties": {
        "deliverable_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "artifact_role": { "type": "string", "minLength": 1 },
        "target_layout_id": { "type": "string", "minLength": 1 },
        "target_stem_id": { "type": "string", "minLength": 1 },
        "target_bus_id": { "type": "string", "minLength": 1 },
        "channel_count": { "type": "integer", "minimum": 1 },
        "status": {
          "type": "string",
          "enum": ["success", "failed", "partial", "invalid_master"]
        },
        "is_valid_master": { "type": "boolean" },
        "planned_stem_count": { "type": ["integer", "null"], "minimum": 0 },
        "decoded_stem_count": { "type": ["integer", "null"], "minimum": 0 },
        "prepared_stem_count": { "type": ["integer", "null"], "minimum": 0 },
        "skipped_stem_count": { "type": ["integer", "null"], "minimum": 0 },
        "rendered_frame_count": { "type": ["integer", "null"], "minimum": 0 },
        "duration_seconds": { "type": ["number", "null"], "minimum": 0 },
        "failure_reason": { "type": ["string", "null"], "minLength": 1 },
        "warning_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "formats": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "output_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "deliverables_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_status",
        "deliverable_count",
        "success_count",
        "failed_count",
        "partial_count",
        "invalid_master_count",
        "valid_master_count",
        "mixed_outcomes",
        "result_bucket",
        "top_failure_reason",
        "top_failure_status"
      ],
      "properties": {
        "overall_status": {
          "type": ["string", "null"],
          "enum": ["success", "failed", "partial", "invalid_master", null]
        },
        "deliverable_count": { "type": "integer", "minimum": 0 },
        "success_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "partial_count": { "type": "integer", "minimum": 0 },
        "invalid_master_count": { "type": "integer", "minimum": 0 },
        "valid_master_count": { "type": "integer", "minimum": 0 },
        "mixed_outcomes": { "type": "boolean" },
        "result_bucket": {
          "type": ["string", "null"],
          "enum": ["valid_master", "success_no_master", "partial_success", "diagnostics_only", "full_failure", null]
        },
        "top_failure_reason": { "type": ["string", "null"] },
        "top_failure_status": {
          "type": ["string", "null"],
          "enum": ["failed", "partial", "invalid_master", null]
        }
      }
    }
  }
}
