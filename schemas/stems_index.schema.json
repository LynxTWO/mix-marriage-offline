{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix-marriage-offline.dev/schemas/stems_index.schema.json",
  "title": "MMO Stems Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "root_dir", "stem_sets", "files"],
  "properties": {
    "version": { "const": "0.1.0" },
    "root_dir": { "type": "string", "minLength": 1 },
    "stem_sets": {
      "type": "array",
      "items": { "$ref": "#/$defs/stem_set" }
    },
    "files": {
      "type": "array",
      "items": { "$ref": "#/$defs/file_entry" }
    }
  },
  "$defs": {
    "posix_rel_path": {
      "type": "string",
      "pattern": "^[^\\\\]+$"
    },
    "raw_tag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "container", "scope", "key", "value", "index"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["format", "stream"]
        },
        "container": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "minLength": 1 },
        "value": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 }
      }
    },
    "tag_bag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw", "normalized", "warnings"],
      "properties": {
        "raw": {
          "type": "array",
          "items": { "$ref": "#/$defs/raw_tag" }
        },
        "normalized": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["technical", "tags"],
      "properties": {
        "technical": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "integer" },
              { "type": "number" },
              { "type": "string" },
              { "type": "boolean" },
              { "type": "null" }
            ]
          }
        },
        "tags": { "$ref": "#/$defs/tag_bag" }
      }
    },
    "stem_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["set_id", "rel_dir", "file_count", "score_hint", "why"],
      "properties": {
        "set_id": {
          "type": "string",
          "pattern": "^STEMSET\\.[0-9a-f]{10}$"
        },
        "rel_dir": { "$ref": "#/$defs/posix_rel_path" },
        "file_count": { "type": "integer", "minimum": 0 },
        "score_hint": { "type": "integer", "minimum": 0 },
        "why": { "type": "string", "minLength": 1 }
      }
    },
    "file_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_id",
        "set_id",
        "rel_path",
        "basename",
        "ext",
        "tokens",
        "folder_tokens"
      ],
      "properties": {
        "file_id": {
          "type": "string",
          "pattern": "^STEMFILE\\.[0-9a-f]{10}$"
        },
        "set_id": {
          "type": "string",
          "pattern": "^STEMSET\\.[0-9a-f]{10}$"
        },
        "rel_path": { "$ref": "#/$defs/posix_rel_path" },
        "basename": { "type": "string", "minLength": 1 },
        "ext": {
          "type": "string",
          "pattern": "^\\.[^.\\\\]+$"
        },
        "tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "folder_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_metadata": {
          "$ref": "#/$defs/source_metadata"
        }
      }
    }
  }
}
